{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cerberus",
  "version": "0.2.4",
  "identifier": "dev.cerberusai.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cerberus",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "theme": "Dark",
        "backgroundColor": "#020204"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: asset: https://asset.localhost; connect-src 'self' https://api.cerberusai.dev ipc: http://ipc.localhost; font-src 'self' data: https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "CerberusAI",
    "shortDescription": "Local-first uncensored AI chat",
    "longDescription": "Cerberus is a local-first chat dashboard for uncensored language models. Runs entirely on your machine via Ollama.",
    "category": "DeveloperTool",
    "copyright": "Copyright (c) 2026 CerberusAI",
    "homepage": "https://cerberusai.dev",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "allowDowngrades": true,
      "wix": {
        "language": ["en-US"]
      },
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false,
        "languages": ["English"]
      }
    },
    "fileAssociations": [],
    "createUpdaterArtifacts": false
  },
  "plugins": {}
}
